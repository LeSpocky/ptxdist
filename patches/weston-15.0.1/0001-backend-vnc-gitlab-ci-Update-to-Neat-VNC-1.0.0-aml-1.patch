+	const char *password = nvnc_auth_creds_get_password(creds);
 	struct passwd *pw = getpwnam(username);
 
 	if (!pw || pw->pw_uid != getuid()) {
 		weston_log("VNC: wrong user '%s'\n", username);
-		return false;
+		nvnc_auth_creds_reject(creds, "Invalid username");
+		return;
