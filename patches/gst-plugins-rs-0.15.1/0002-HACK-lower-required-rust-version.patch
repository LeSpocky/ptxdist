From: Michael Olbrich <m.olbrich@pengutronix.de>
Date: Sat, 31 Jan 2026 23:58:45 +0100
Subject: [PATCH] HACK: lower required rust version

1.92 is not actually needed and this allows building with
OSELAS.Toolchain-2025.11.1.

Signed-off-by: Michael Olbrich <m.olbrich@pengutronix.de>
---
 Cargo.toml                                                              | 2 +-
 .../workspaces/gstreamer-rs-0.25.1+3d56963cfca1/Cargo.toml              | 2 +-
 .../workspaces/gtk-rs-core-0.22.2+484fbe01e74f/Cargo.toml               | 2 +-
 ptxdist-cargo-home/workspaces/gtk4-rs-0.11.0+12259c689cf3/Cargo.toml    | 2 +-
 4 files changed, 4 insertions(+), 4 deletions(-)

diff --git a/Cargo.toml b/Cargo.toml
index 07809bd2ee87..ff052217434c 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -151,7 +151,7 @@ lto = "off"
 version = "0.15.1"
 repository = "https://gitlab.freedesktop.org/gstreamer/gst-plugins-rs"
 edition = "2024"
-rust-version = "1.92"
+rust-version = "1.91"
 
 [workspace.dependencies]
 glib = { git = "https://github.com/gtk-rs/gtk-rs-core", branch = "0.22", version = "0.22.0" }
diff --git a/ptxdist-cargo-home/workspaces/gstreamer-rs-0.25.1+3d56963cfca1/Cargo.toml b/ptxdist-cargo-home/workspaces/gstreamer-rs-0.25.1+3d56963cfca1/Cargo.toml
index c6bb6c502349..65e21b2e0c56 100644
--- a/ptxdist-cargo-home/workspaces/gstreamer-rs-0.25.1+3d56963cfca1/Cargo.toml
+++ b/ptxdist-cargo-home/workspaces/gstreamer-rs-0.25.1+3d56963cfca1/Cargo.toml
@@ -124,7 +124,7 @@ categories = ["api-bindings", "multimedia"]
 repository = "https://gitlab.freedesktop.org/gstreamer/gstreamer-rs"
 homepage = "https://gstreamer.freedesktop.org"
 edition = "2024"
-rust-version = "1.92"
+rust-version = "1.91"
 
 [workspace.dependencies]
 gio = { git = "https://github.com/gtk-rs/gtk-rs-core", branch = "0.22", version = "0.22.0" }
diff --git a/ptxdist-cargo-home/workspaces/gtk-rs-core-0.22.2+484fbe01e74f/Cargo.toml b/ptxdist-cargo-home/workspaces/gtk-rs-core-0.22.2+484fbe01e74f/Cargo.toml
index 968aadf18e48..447a1406b297 100644
--- a/ptxdist-cargo-home/workspaces/gtk-rs-core-0.22.2+484fbe01e74f/Cargo.toml
+++ b/ptxdist-cargo-home/workspaces/gtk-rs-core-0.22.2+484fbe01e74f/Cargo.toml
@@ -65,7 +65,7 @@ repository = "https://github.com/gtk-rs/gtk-rs-core"
 license = "MIT"
 exclude = ["gir-files/*"]
 edition = "2024"
-rust-version = "1.92"
+rust-version = "1.91"
 
 [workspace.dependencies]
 libc = "0.2"
diff --git a/ptxdist-cargo-home/workspaces/gtk4-rs-0.11.0+12259c689cf3/Cargo.toml b/ptxdist-cargo-home/workspaces/gtk4-rs-0.11.0+12259c689cf3/Cargo.toml
index 51c81bc139de..8e70facd0d39 100644
--- a/ptxdist-cargo-home/workspaces/gtk4-rs-0.11.0+12259c689cf3/Cargo.toml
+++ b/ptxdist-cargo-home/workspaces/gtk4-rs-0.11.0+12259c689cf3/Cargo.toml
@@ -41,7 +41,7 @@ edition = "2024"
 homepage = "https://gtk-rs.org/gtk4-rs"
 license = "MIT"
 repository = "https://github.com/gtk-rs/gtk4-rs"
-rust-version = "1.92"
+rust-version = "1.91"
 version = "0.11.0"
 
 [workspace.dependencies]
