From: Michael Olbrich <m.olbrich@pengutronix.de>
Date: Sun, 5 Jul 2026 08:07:02 +0200
Subject: [PATCH] run native code generators with qemu

Host tools cannot be used because they would generate code based on
properties of the host architecture, e.g. pointer size.

Signed-off-by: Michael Olbrich <m.olbrich@pengutronix.de>
---
 node.gyp                 | 3 +++
 tools/v8_gypfiles/v8.gyp | 3 +++
 2 files changed, 6 insertions(+)

diff --git a/node.gyp b/node.gyp
index 1779a57cce36..befd205342d9 100644
--- a/node.gyp
+++ b/node.gyp
@@ -1073,6 +1073,7 @@
             '<(SHARED_INTERMEDIATE_DIR)/node_javascript.cc',
           ],
           'action': [
+            '<(PRODUCT_DIR)/tool-wrapper',
             '<(node_js2c_exec)',
             '<@(_outputs)',
             'lib',
@@ -1139,6 +1140,7 @@
                     '<(SHARED_INTERMEDIATE_DIR)/node_snapshot.cc',
                   ],
                   'action': [
+                    '<(PRODUCT_DIR)/tool-wrapper',
                     '<(node_mksnapshot_exec)',
                     '--build-snapshot',
                     '<(node_snapshot_main)',
@@ -1152,6 +1154,7 @@
                   'action_name': 'node_mksnapshot',
                   'process_outputs_as_sources': 1,
                   'inputs': [
+                    '<(PRODUCT_DIR)/tool-wrapper',
                     '<(node_mksnapshot_exec)',
                   ],
                   'outputs': [
diff --git a/tools/v8_gypfiles/v8.gyp b/tools/v8_gypfiles/v8.gyp
index 945aa0aa501d..99b1f05d85f6 100644
--- a/tools/v8_gypfiles/v8.gyp
+++ b/tools/v8_gypfiles/v8.gyp
@@ -149,6 +149,7 @@
             '<@(torque_outputs_inc)',
           ],
           'action': [
+            '<(PRODUCT_DIR)/tool-wrapper',
             '<(PRODUCT_DIR)/<(EXECUTABLE_PREFIX)torque<(EXECUTABLE_SUFFIX)',
             '-o', '<(SHARED_INTERMEDIATE_DIR)/torque-generated',
             '-v8-root', '<(V8_ROOT)',
@@ -261,6 +262,7 @@
         {
           'action_name': 'generate_bytecode_builtins_list_action',
           'inputs': [
+            '<(PRODUCT_DIR)/tool-wrapper',
             '<(PRODUCT_DIR)/<(EXECUTABLE_PREFIX)bytecode_builtins_list_generator<(EXECUTABLE_SUFFIX)',
           ],
           'outputs': [
@@ -409,6 +411,7 @@
             ],
           },
           'inputs': [
+            '<(PRODUCT_DIR)/tool-wrapper',
             '<(mksnapshot_exec)',
           ],
           'outputs': [
